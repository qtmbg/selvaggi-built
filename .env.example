# Copy this file to .env in the /server directory.
# NEVER commit .env. NEVER ship keys to the client.

# ============================================================
# GOOGLE GEMINI (free tier). required for /api/ai
# Get a key at https://aistudio.google.com/apikey
# ============================================================
GEMINI_API_KEY=REQUIRED
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# PROXY HOST
# ============================================================
PORT=3000

# ============================================================
# RESEND (free tier, 3,000 emails/month). required before
# /api/contact returns 200. Until this is configured the
# endpoint returns 503 and the front end shows the fallback
# "Sending failed" message.
# Sign up at https://resend.com, verify the selvaggibuilt.com
# domain (DNS records), then create an API key.
# ============================================================
RESEND_API_KEY=REQUIRED
RESEND_FROM=Selvaggi Built Website <notifications@selvaggibuilt.com>
SALES_INBOX=sales@selvaggibuilt.com
