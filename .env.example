# Copy this file to .env in the /server directory.
# NEVER commit .env. NEVER ship keys to the client.

# ============================================================
# CLAUDE SONNET (Anthropic). required for /api/ai
# ============================================================
ANTHROPIC_API_KEY=sk-ant-REQUIRED
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# PROXY HOST
# ============================================================
PORT=3000

# ============================================================
# CRM / FORM HANDLER. required before /api/contact returns 200
# Until this is configured the endpoint returns 503 and the
# front end shows the fallback "Sending failed" message.
# Connect to your CRM webhook (Salesforce, HubSpot, Pipedrive)
# or a transactional email service (Postmark, SendGrid, SES)
# that forwards to sales@selvaggibuilt.com.
# ============================================================
CRM_WEBHOOK_URL=REQUIRED-PROD-CRM-OR-EMAIL-RELAY-URL
CRM_AUTH_HEADER=
SALES_INBOX=sales@selvaggibuilt.com
